# ====================================================================
# Supabase
# ====================================================================
# 公開キー(クライアントサイドで使用可能)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# 秘密キー(サーバーサイドのみ・絶対にクライアントに露出させない)
# Stripe Webhookやサーバー側の管理操作で使用
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ====================================================================
# Site URL (メール認証のリダイレクト先)
# ====================================================================
# 開発: http://localhost:3000
# 本番: https://[your-vercel-url].vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ====================================================================
# Anthropic
# ====================================================================
# Anthropic API Key(サーバーサイドのみ・絶対にクライアントに露出させない)
# 取得: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxx

# ====================================================================
# PDF 生成(本番のみ)
# ====================================================================
# @sparticuz/chromium-min が起動時に取得する Chromium バイナリ(pack.tar)の HTTPS URL。
# ローカル開発では puppeteer(devDep)が ~/.cache/puppeteer の Chromium を使うため不要。
# Vercel(本番)では @sparticuz/chromium-min がバイナリを内包しないので、別途
# 任意の HTTPS ホスト(R2 等)に chromium-v149 系の pack.tar を置き、その URL を指定する。
# バージョンは package.json の "@sparticuz/chromium-min" のメジャー(現在 v149)と揃えること。
# 例: https://your-cdn.example.com/chromium/chromium-v149.0.0-pack.tar
# ※ pack.tar のホスティングと本番 env 設定は別フェーズ(env 準備フェーズ)で行う。
CHROMIUM_REMOTE_EXEC_PATH=

# ====================================================================
# 外部連携(オプション機能:会議録音 自動連携 アドオン)
# ====================================================================
# 全て未設定でもアプリは動作する(連携機能のみ無効化される)。
# 設定手順は docs/integrations-setup.md を参照。

# OAuth state パラメータ(CSRF 対策)の HMAC 秘密鍵。32 文字以上推奨。
# 例: openssl rand -hex 32
OAUTH_STATE_SECRET=

# Zoom App(User-managed OAuth)
# 取得: https://marketplace.zoom.us/develop/create
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Webhook(Cloud Recording 完了通知)の URL Verification 用 secret token
ZOOM_WEBHOOK_SECRET=

# Google OAuth 2.0(Drive 経由 Meet 録画取込)
# 取得: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe(組織 課金 + アドオン。 未設定 なら Webhook は 503 を 返す)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# 「会議 録音 自動 連携」 アドオン の Stripe Price ID
STRIPE_PRICE_MEETING_RECORDING_AUTO=

# --------------------------------------------------------------------
# 組織 課金 プラン (Standard / Extra Seat / AI Boost) 用 の Price ID 6 本。
#
# 事前 準備 (Stripe Dashboard):
#   1. Products → New Product で 以下 3 プロダクト を 作成:
#      - Maira Standard (Base 3 席 込 み)
#      - Maira Extra Seat (Base 超過 分 の 1 席 追加 単価)
#      - Maira AI Boost (Standard Pro 化 アドオン)
#   2. 各 プロダクト に 月額 (JPY) と 年額 (JPY) の 2 Price を 作成。 計 6 Price ID。
#   3. metadata に scope=organization を 付ける と webhook 側 で 拾い やすい (任意)。
#
# 6 本 全て を セット しない と app/api/webhooks/stripe/route.ts が
# org_prices_missing で 503 を 返す。 dev / prod で Price ID は 分ける こと。
# 詳細 は docs/integrations-setup.md 「Stripe 組織 課金」 節 参照。
# --------------------------------------------------------------------
STRIPE_PRICE_STANDARD_BASE_MONTHLY=
STRIPE_PRICE_STANDARD_BASE_YEARLY=
STRIPE_PRICE_EXTRA_SEAT_MONTHLY=
STRIPE_PRICE_EXTRA_SEAT_YEARLY=
STRIPE_PRICE_AI_BOOST_MONTHLY=
STRIPE_PRICE_AI_BOOST_YEARLY=

# ====================================================================
# メール 送信 (Resend)
# ====================================================================
# 未設定 なら 招待 / 通知 / 面談 / 資料 請求 の 各 メール 送信 API が 503 を 返す。
# 取得: https://resend.com/api-keys
RESEND_API_KEY=
# 送信 元 アドレス (例: notifications@maira.pro)。 verify 済 の ドメイン を 使う。
EMAIL_FROM=
# 問い合わせ通知 の 送信先 (運営 側 の 受信 メール)。 CONTACT_NOTIFICATION_FROM は
# 差出人 表示 用。 未設定 なら /api/contact が 500 に なる。
CONTACT_NOTIFICATION_TO=
CONTACT_NOTIFICATION_FROM=

# ====================================================================
# Cron (Vercel Cron) 用 秘密鍵
# ====================================================================
# Vercel Cron から の 呼び出し 認証。 Vercel の cron が Authorization: Bearer
# CRON_SECRET を 送って くる ため、 INTAKE_CRON_SECRET と 同 値 で よい。
# Vercel Pro / Enterprise プラン 必須 (Hobby では cron 自体 が 動か ない)。
CRON_SECRET=

# Career intake バックグラウンド ジョブ pickup の 認証 ヘッダ 値
INTAKE_CRON_SECRET=

# ====================================================================
# レート 制限 / セキュリティ 補助
# ====================================================================
# パスワード リセット チケット の HMAC 鍵 (Batch 2 H1 修正)。
# 未設定 の 場合 は SUPABASE_JWT_SECRET に fallback。
PW_RESET_TICKET_SECRET=

# ====================================================================
# Field-encryption 鍵 (絶対 に クライアント に 露出 させない)
# ====================================================================
# AES-256-GCM で 機密 フィールド を 暗号化 する 際 の 鍵 map (JSON)。
# 例: {"1":"<base64 32-byte key>"}
# バージョン 管理 が 前提 で、 現在 使う バージョン を FIELD_ENCRYPTION_CURRENT_VERSION に。
FIELD_ENCRYPTION_KEYS=
FIELD_ENCRYPTION_CURRENT_VERSION=
